modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Sports Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'while true; do python main.py; echo \"Bot leállt, újraindítás 5 mp múlva...\"; sleep 5; done'"

[[workflows.workflow]]
name = "Football Corners Bot"
mode = "sequential"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'while true; do python corners_bot.py; echo \"Bot leállt, újraindítás 5 mp múlva...\"; sleep 5; done'"

[[workflows.workflow]]
name = "artifacts/stats-dashboard: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/stats-dashboard"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/stats-dashboard run dev"
cwd = "./artifacts/stats-dashboard"
waitForPort = 22884
router = "path"

[workflows.workflow.tasks.env]
PORT = "22884"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sports Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Football Corners Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Coupon Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Basketball Bot"

[[workflows.workflow]]
name = "Coupon Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'while true; do python coupon_bot.py; echo \"Coupon Bot leállt, újraindítás 5 mp múlva...\"; sleep 5; done'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Basketball Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'while true; do python basketball_bot.py; echo \"Bot leállt, újraindítás 5 mp múlva...\"; sleep 5; done'"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
CORNERS_CHAT_ID = "6617439213"
TT_BOT_DISABLED = "false"
