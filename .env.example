# ============================================================
#  SPORTS BOTS – Környezeti változók sablonja
#  Másold ezt .env névvel ugyanabba a mappába, és töltsd ki!
# ============================================================

# ── Adatbázis (ugyanaz minden botnál – Supabase PostgreSQL) ─
# A statisztika itt tárolódik, helyi futásnál is ugyanaz az adat!
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Kosárlabda Bot (basketball_bot.py) ──────────────────────
BASKETBALL_BOT_TOKEN=
BASKETBALL_CHAT_ID=

# ── BTTS Bot (btts_bot.py) ──────────────────────────────────
BTTS_BOT_TOKEN=
COUPON_CHAT_ID=

# ── Foci 2.5 O/U Bot (football_25_bot.py) ──────────────────
# Megjegyzés: football_25_bot.py automatikusan elindítja a btts_bot.py-t is!
# Mindkét fájlnak ugyanabban a mappában kell lennie.
COUPON_BOT_TOKEN=

# ── Szöglet Bot (corners_bot.py) ────────────────────────────
CORNERS_BOT_TOKEN=
CORNERS_CHAT_ID=

# ── Cricket IPL Bot (cricket_ipl_bot.py) ────────────────────
CRICKET_BOT_TOKEN=
CRICKET_CHAT_ID=

# ── TT / Sports Bot (main.py) ───────────────────────────────
# Megjegyzés: main.py elindítja az nba_rest_bot.py-t is (ha megvan a fájl)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MULTI_SPORT_BOT_TOKEN=
MULTI_SPORT_CHAT_ID=

# ── Opcionális ───────────────────────────────────────────────
# Ha SofaScore blokkolja a gépedet, állítsd be saját proxy URL-t:
# SOFASCORE_BASE=https://www.sofascore.com/api/v1

# Sports API (main.py TT tippekhez, ha van előfizetés):
# SPORTS_API_KEY=
